--- a/crates/ui/src/input/element.rs
+++ b/crates/ui/src/input/element.rs
@@ -2025,8 +2025,14 @@ impl Element for TextElement {
 
         // Paint blinking cursor
         if focused && show_cursor {
-            if let Some(cursor_bounds) = prepaint.cursor_bounds_with_scroll() {
-                window.paint_quad(fill(cursor_bounds, cx.theme().caret));
+            if let Some(mut cursor_bounds) = prepaint.cursor_bounds_with_scroll() {
+                if self.state.read(cx).cursor_block {
+                    cursor_bounds.size.width = px(8.0);
+                    let block_color = cx.theme().caret.mix_oklab(cx.theme().transparent, 0.5);
+                    window.paint_quad(fill(cursor_bounds, block_color));
+                } else {
+                    window.paint_quad(fill(cursor_bounds, cx.theme().caret));
+                }
             }
         }
 
