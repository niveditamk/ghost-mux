@@ -55,6 +55,36 @@ impl ResizableState {
         &self.sizes
     }
 
+    /// Create a new [`ResizableState`] pre-seeded with the given size ratios.
+    ///
+    /// Ratios should sum to 1.0 and have the same length as the number of
+    /// panels in the group.  The sizes are expressed as fractions of a large
+    /// virtual container so that none of them equal `PANEL_MIN_SIZE` (100 px),
+    /// which would cause `update_panel_size` to overwrite them on first paint.
+    /// `adjust_to_container_size` rescales them to the real bounds once the
