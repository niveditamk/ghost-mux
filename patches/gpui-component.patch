+    /// Set the text of the input field without requiring Window reference (for async tasks).
+    pub fn set_value_no_window(
+        &mut self,
+        value: impl Into<SharedString>,
+        cx: &mut Context<Self>,
+    ) {
+        self.history.ignore = true;
+        self.emit_events = false;
+        
+        let text: SharedString = value.into();
+        let old_text = self.text.clone();
+        let range = 0..self.text.chars().map(|c| c.len_utf16()).sum();
+        
+        self.silent_replace_text = true;
+        self.text.replace(range.clone(), &text);
+        let new_offset = self.text.len();
+        
+        self.display_map
+            .adjust_folds_for_edit(&old_text, &range, &text);
+        self.display_map
+            .on_text_changed(&self.text, &range, &Rope::from(text.as_str()), cx);
+        self.reset_highlighter(cx);
+            
+        self.selected_range = (new_offset..new_offset).into();
+        self.ime_marked_range.take();
+        self.update_preferred_column();
+        
+        self.silent_replace_text = false;
+        self.history.ignore = false;
+        self.emit_events = true;
+
+        // Move scroll to top
+        self.scroll_handle.set_offset(point(px(0.), px(0.)));
+
+        self.history.clear();
+        cx.notify();
+    }
+
     /// Insert text at the current cursor position.
     ///
     /// And the cursor will be moved to the end of inserted text.
diff --git a/crates/ui/src/resizable/mod.rs b/crates/ui/src/resizable/mod.rs
index ed74d32c..9483c4d3 100644
--- a/crates/ui/src/resizable/mod.rs
+++ b/crates/ui/src/resizable/mod.rs
@@ -55,6 +55,36 @@ impl ResizableState {
         &self.sizes
     }
 
+    /// Create a new [`ResizableState`] pre-seeded with the given size ratios.
+    ///
+    /// Ratios should sum to 1.0 and have the same length as the number of
+    /// panels in the group.  The sizes are expressed as fractions of a large
+    /// virtual container so that none of them equal `PANEL_MIN_SIZE` (100 px),
+    /// which would cause `update_panel_size` to overwrite them on first paint.
+    /// `adjust_to_container_size` rescales them to the real bounds once the
+    /// first prepaint fires.
+    pub fn new_with_ratios(ratios: &[f32]) -> Self {
+        const VIRTUAL: f32 = 10_000.0;
+        let sizes: Vec<Pixels> = ratios
+            .iter()
+            .map(|r| px((r * VIRTUAL).max(0.0)))
+            .collect();
+        let panels: Vec<ResizablePanelState> = sizes
+            .iter()
+            .map(|&s| ResizablePanelState {
+                size: Some(s),
+                ..Default::default()
+            })
+            .collect();
+        Self {
+            axis: Axis::Horizontal,
+            panels,
+            sizes,
+            resizing_panel_ix: None,
+            bounds: Bounds::default(),
+        }
+    }
+
     /// Programmatically resize the panel at `ix` to `size`, redistributing
     /// space among siblings using the same logic as a drag.
     ///
