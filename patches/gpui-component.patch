+    /// Set the text of the input field without requiring Window reference (for async tasks).
+    pub fn set_value_no_window(
+        &mut self,
+        value: impl Into<SharedString>,
+        cx: &mut Context<Self>,
+    ) {
+        self.history.ignore = true;
+        self.emit_events = false;
+        
+        let text: SharedString = value.into();
+        let old_text = self.text.clone();
+        let range = 0..self.text.chars().map(|c| c.len_utf16()).sum();
+        
+        self.silent_replace_text = true;
+        self.text.replace(range.clone(), &text);
+        let new_offset = self.text.len();
+        
+        self.display_map
+            .adjust_folds_for_edit(&old_text, &range, &text);
+        self.display_map
+            .on_text_changed(&self.text, &range, &Rope::from(text.as_str()), cx);
+        self.reset_highlighter(cx);
+            
+        self.selected_range = (new_offset..new_offset).into();
+        self.ime_marked_range.take();
+        self.update_preferred_column();
+        
+        self.silent_replace_text = false;
+        self.history.ignore = false;
+        self.emit_events = true;
+
+        // Move scroll to top
+        self.scroll_handle.set_offset(point(px(0.), px(0.)));
